# Copie para backend.hcl (não commitar segredos) e rode:
#   terraform init -backend-config backend.hcl -reconfigure
#
# Crie o bucket S3 manualmente (Academy costuma exigir) e habilite versionamento.

# O nome do bucket usa o ID da conta AWS atual (os pipelines derivam automaticamente):
#   terraformbucket-fiap-ch3-<AWS_ACCOUNT_ID>
bucket         = "terraformbucket-fiap-ch3-360230583529"
key            = "togglemaster/fase3/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
# use_lockfile agora está habilitado diretamente no bloco backend "s3" em versions.tf
